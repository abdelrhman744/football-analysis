# ── CV Model ──────────────────────────────────────────────────────────────────
# Path to your trained YOLOv8 .pt file.
# Default: backend/models_weights/best.pt
MODEL_WEIGHTS_PATH=models_weights/best.pt

# Class IDs as defined in best.pt
# 0: ball
# 1: goalkeeper
# 2: player
# 3: referee
CLASS_BALL=0
CLASS_GK=1
CLASS_PLAYER=2
CLASS_REFEREE=3

# Inference settings
YOLO_CONF=0.35
YOLO_IOU=0.45
YOLO_IMGSZ=1280

# Process every Nth frame (1 = all frames, 2 = every other, etc.)
FRAME_STRIDE=2

# ── ByteTrack ─────────────────────────────────────────────────────────────────
BT_TRACK_THRESH=0.25
BT_TRACK_BUFFER=30
BT_MATCH_THRESH=0.8
BT_FRAME_RATE=25

# ── External APIs ─────────────────────────────────────────────────────────────
FOOTBALL_API_KEY=your_api_football_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here