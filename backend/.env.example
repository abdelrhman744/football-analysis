# ── CV Model ──────────────────────────────────────────────────────────────────
# Path to your trained YOLOv8 .pt file.
# Default: backend/models_weights/player_ball_detector.pt
MODEL_WEIGHTS_PATH=models_weights/player_ball_detector.pt

# Class IDs as defined in your model's data.yaml
CLASS_PLAYER=0
CLASS_BALL=1
CLASS_REFEREE=2
CLASS_GOALKEEPER=3

# Inference settings
YOLO_CONF=0.35
YOLO_IOU=0.45
YOLO_IMGSZ=1280

# Process every Nth frame (1 = all frames, 2 = every other, etc.)
FRAME_STRIDE=2

# ── ByteTrack ─────────────────────────────────────────────────────────────────
BT_TRACK_THRESH=0.25
BT_TRACK_BUFFER=30
BT_MATCH_THRESH=0.8
BT_FRAME_RATE=25

# ── External APIs ─────────────────────────────────────────────────────────────
FOOTBALL_API_KEY=your_api_football_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
